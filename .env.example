# ─── Nansen API ──────────────────────────────────────────────────────────────
# Get your key at: https://app.nansen.ai/auth/agent-setup
NANSEN_API_KEY=your_nansen_api_key_here
NANSEN_API_BASE_URL=https://api.nansen.ai

# ─── OKX OnchainOS ───────────────────────────────────────────────────────────
# Get credentials at: https://web3.okx.com/onchainos
ONCHAINOS_API_KEY=your_onchainos_api_key_here
ONCHAINOS_API_SECRET=your_onchainos_api_secret_here
ONCHAINOS_WALLET_ADDRESS=your_wallet_address_here
ONCHAINOS_BASE_URL=https://web3.okx.com/api/v1

# ─── Agent Config ─────────────────────────────────────────────────────────────
# Mode: monitor (read-only) | alert (notify) | auto-trade (execute)
AGENT_MODE=monitor

# Maximum position size per trade in USD (safety cap)
MAX_TRADE_SIZE_USD=100

# Minimum smart money confidence to trigger alerts (0-1)
SMART_MONEY_MIN_CONFIDENCE=0.7

# Risk level: low | medium | high
RISK_LEVEL=medium

# (Legacy) X Layer RPC — no longer primary chain but kept for config compat
DEFAULT_CHAIN=xlayer
XLAYER_RPC_URL=https://rpc.xlayer.tech
XLAYER_CHAIN_ID=196

# Agent HTTP server port
AGENT_PORT=3100
